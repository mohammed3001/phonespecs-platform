# =============================================================================
# MobilePlatform — Environment Variables
# =============================================================================
# Copy to .env and fill in production values before deploying.
#
# DEPLOYMENT CHECKLIST:
#   1. Vercel → Settings → General → Root Directory = /
#   2. Set all variables below in Vercel → Settings → Environment Variables
#   3. Generate a strong NEXTAUTH_SECRET: openssl rand -base64 32
#   4. Ensure DATABASE_URL points to your production PostgreSQL
#   5. Set NEXT_PUBLIC_SITE_URL to your production domain (e.g. https://mobileplatform.com)
#   6. If using Meilisearch, set MEILISEARCH_URL + MEILISEARCH_MASTER_KEY
# =============================================================================

# Database (required)
DATABASE_URL=postgresql://mp_dev:mp_dev_password@localhost:5432/mobileplatform

# Auth (required)
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Site URL — canonical URL for SEO: sitemap, robots, Open Graph (required for production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Meilisearch — search engine (optional, search features degrade gracefully)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=mp_dev_master_key_change_in_production

# Redis — for BullMQ job queues (optional)
# REDIS_URL=redis://localhost:6379
