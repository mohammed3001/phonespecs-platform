// ============================================================
// PhoneSpec Platform - Prisma Schema
// PostgreSQL 15 (Supabase)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── SYSTEM SETTINGS ─────────────────────────────────────────

model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  group     String   @default("general")
  type      String   @default("string") // string | boolean | number | json | secret
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
  @@map("system_settings")
}

// ─── ADMIN USERS ─────────────────────────────────────────────

model AdminUser {
  id               String    @id @default(cuid())
  username         String    @unique
  email            String    @unique
  passwordHash     String
  role             AdminRole @default(EDITOR)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  loginAttempts    Int       @default(0)
  lockedUntil      DateTime?
  allowedIps       String[]  @default([])
  lastLoginAt      DateTime?
  lastLoginIp      String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions AdminSession[]
  auditLogs AuditLog[]

  @@map("admin_users")
}

model AdminSession {
  id        String    @id @default(cuid())
  adminId   String
  token     String    @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("admin_sessions")
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String?
  action    String
  entity    String?
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  admin AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

// ─── LANGUAGES ───────────────────────────────────────────────

model Language {
  id        String   @id @default(cuid())
  code      String   @unique // en, ar, ku
  name      String   // English, العربية
  nativeName String
  direction String   @default("ltr") // ltr | rtl
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  flagIcon  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations Translation[]

  @@map("languages")
}

model Translation {
  id         String   @id @default(cuid())
  languageId String
  namespace  String   @default("common") // common, phone, admin, seo
  key        String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([languageId, namespace, key])
  @@index([languageId, namespace])
  @@map("translations")
}

// ─── BRANDS ──────────────────────────────────────────────────

model Brand {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  logoUrl     String?
  description String?
  website     String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  phones   Phone[]
  seoMeta  SeoMeta[]
  brandTranslations BrandTranslation[]

  @@map("brands")
}

model BrandTranslation {
  id          String @id @default(cuid())
  brandId     String
  languageCode String
  name        String
  description String?

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, languageCode])
  @@map("brand_translations")
}

// ─── SPEC CATEGORIES & ATTRIBUTES ────────────────────────────

model SpecCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String   // Display/English fallback
  sortOrder Int      @default(0)
  icon      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attributes SpecAttribute[]
  specCategoryTranslations SpecCategoryTranslation[]

  @@map("spec_categories")
}

model SpecCategoryTranslation {
  id           String @id @default(cuid())
  categoryId   String
  languageCode String
  name         String

  category SpecCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, languageCode])
  @@map("spec_category_translations")
}

model SpecAttribute {
  id           String   @id @default(cuid())
  categoryId   String
  slug         String   @unique
  name         String
  unit         String?  // MHz, GB, mAh
  type         String   @default("text") // text | number | boolean | list | range
  isComparable Boolean  @default(true)
  isFilterable Boolean  @default(true)
  isHighlight  Boolean  @default(false) // show on card
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category   SpecCategory @relation(fields: [categoryId], references: [id])
  phoneSpecs PhoneSpec[]
  specAttributeTranslations SpecAttributeTranslation[]

  @@map("spec_attributes")
}

model SpecAttributeTranslation {
  id           String @id @default(cuid())
  attributeId  String
  languageCode String
  name         String
  unit         String?

  attribute SpecAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([attributeId, languageCode])
  @@map("spec_attribute_translations")
}

// ─── PHONES ──────────────────────────────────────────────────

model Phone {
  id            String      @id @default(cuid())
  brandId       String
  slug          String      @unique
  name          String
  modelNumber   String?
  status        PhoneStatus @default(UPCOMING)
  releaseDate   DateTime?
  announcedDate DateTime?
  discontinuedDate DateTime?
  priceUsd      Decimal?    @db.Decimal(10, 2)
  priceIqd      Decimal?    @db.Decimal(10, 0)
  popularity    Int         @default(0)
  viewCount     Int         @default(0)
  isActive      Boolean     @default(true)
  isFeatured    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  brand         Brand         @relation(fields: [brandId], references: [id])
  specs         PhoneSpec[]
  images        PhoneImage[]
  videos        PhoneVideo[]
  reviews       Review[]
  seoMeta       SeoMeta[]
  phoneTranslations PhoneTranslation[]
  compareItems  CompareItem[]

  @@index([brandId])
  @@index([status])
  @@index([isFeatured])
  @@map("phones")
}

model PhoneTranslation {
  id           String @id @default(cuid())
  phoneId      String
  languageCode String
  name         String
  description  String?
  highlights   String[] @default([])

  phone Phone @relation(fields: [phoneId], references: [id], onDelete: Cascade)

  @@unique([phoneId, languageCode])
  @@map("phone_translations")
}

model PhoneSpec {
  id          String @id @default(cuid())
  phoneId     String
  attributeId String
  value       String
  displayValue String? // formatted display value

  phone     Phone         @relation(fields: [phoneId], references: [id], onDelete: Cascade)
  attribute SpecAttribute @relation(fields: [attributeId], references: [id])

  @@unique([phoneId, attributeId])
  @@index([phoneId])
  @@map("phone_specs")
}

model PhoneImage {
  id        String   @id @default(cuid())
  phoneId   String
  url       String
  thumbUrl  String?
  alt       String?
  width     Int?
  height    Int?
  format    String?
  size      Int?     // bytes
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  phone Phone @relation(fields: [phoneId], references: [id], onDelete: Cascade)

  @@index([phoneId])
  @@map("phone_images")
}

model PhoneVideo {
  id        String   @id @default(cuid())
  phoneId   String
  url       String
  thumbUrl  String?
  title     String?
  format    String?  // mp4 | webm | mov
  duration  Int?     // seconds
  width     Int?
  height    Int?
  size      Int?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  phone Phone @relation(fields: [phoneId], references: [id], onDelete: Cascade)

  @@index([phoneId])
  @@map("phone_videos")
}

enum PhoneStatus {
  UPCOMING
  AVAILABLE
  DISCONTINUED
}

// ─── REVIEWS ─────────────────────────────────────────────────

model Review {
  id          String       @id @default(cuid())
  phoneId     String
  languageCode String      @default("en")
  title       String
  content     String       @db.Text
  rating      Decimal      @db.Decimal(3, 1)
  pros        String[]     @default([])
  cons        String[]     @default([])
  verdict     String?
  isPublished Boolean      @default(false)
  publishedAt DateTime?
  authorName  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  phone Phone @relation(fields: [phoneId], references: [id], onDelete: Cascade)

  @@index([phoneId])
  @@map("reviews")
}

// ─── SEO ─────────────────────────────────────────────────────

model SeoMeta {
  id            String   @id @default(cuid())
  entityType    String   // phone | brand | page | category
  entityId      String?
  languageCode  String   @default("en")
  path          String?  // /en/phones/samsung-galaxy-s24
  title         String?
  description   String?
  keywords      String?
  ogTitle       String?
  ogDescription String?
  ogImage       String?
  twitterTitle  String?
  twitterDesc   String?
  twitterImage  String?
  canonicalUrl  String?
  robotsIndex   Boolean  @default(true)
  robotsFollow  Boolean  @default(true)
  jsonLd        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  phone Phone? @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "seo_phone_fk")
  brand Brand? @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "seo_brand_fk")

  @@unique([entityType, entityId, languageCode])
  @@index([entityType, entityId])
  @@map("seo_meta")
}

// ─── COMPARE ─────────────────────────────────────────────────

model CompareItem {
  id        String   @id @default(cuid())
  sessionId String
  phoneId   String
  createdAt DateTime @default(now())

  phone Phone @relation(fields: [phoneId], references: [id], onDelete: Cascade)

  @@unique([sessionId, phoneId])
  @@index([sessionId])
  @@map("compare_items")
}

// ─── PAYMENTS ────────────────────────────────────────────────

model PaymentGateway {
  id          String   @id @default(cuid())
  provider    String   @unique // zaincash | qicard | fib
  name        String
  isEnabled   Boolean  @default(false)
  environment String   @default("sandbox") // sandbox | production
  config      Json     // encrypted credentials
  webhookUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]

  @@map("payment_gateways")
}

model Transaction {
  id              String            @id @default(cuid())
  gatewayId       String
  externalId      String?           // gateway's transaction ID
  amount          Decimal           @db.Decimal(12, 2)
  currency        String            @default("IQD")
  status          TransactionStatus @default(PENDING)
  metadata        Json?
  callbackData    Json?
  errorMessage    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  gateway PaymentGateway @relation(fields: [gatewayId], references: [id])

  @@index([gatewayId])
  @@index([status])
  @@map("transactions")
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

// ─── CLOUDFLARE SETTINGS ─────────────────────────────────────

model CloudflareConfig {
  id         String   @id @default(cuid())
  apiKey     String   // encrypted
  accountId  String
  zoneId     String
  cdnEnabled Boolean  @default(false)
  wafEnabled Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("cloudflare_config")
}

// ─── MEDIA LIBRARY ───────────────────────────────────────────

model MediaFile {
  id         String   @id @default(cuid())
  bucket     String   // supabase bucket name
  path       String
  url        String
  thumbUrl   String?
  filename   String
  mimeType   String
  size       Int
  width      Int?
  height     Int?
  duration   Int?
  alt        String?
  isPublic   Boolean  @default(true)
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@index([bucket])
  @@map("media_files")
}
